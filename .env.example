# Copy this file to .env (gitignored) and fill in real values.
# Real secrets are NEVER committed -- only this template is.
#
# NOTE: the Earth Engine OAuth token is NOT stored here. It lives in
# ~/.config/earthengine/credentials (outside the repo), managed by the EE CLI.
# Below is only non-secret config + a place for future real secrets.

# Earth Engine cloud project id (not secret; used by scripts/fetch_earth_engine.py)
EE_PROJECT=your-gee-project-id

# Future real secrets go here, e.g.:
# AGMARKNET_API_KEY=
